generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ANALYST
  EMPLOYEE
}

enum IncidentStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentType {
  DATA_LEAK
  DDOS
  MALWARE
  PHISHING
  UNAUTHORIZED_ACCESS
  INSIDER_THREAT
  OTHER
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(EMPLOYEE)
  department String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdIncidents  Incident[]  @relation("CreatedBy")
  assignedIncidents Incident[]  @relation("AssignedTo")
  comments          Comment[]
  uploadedFiles     File[]
  auditLogs         AuditLog[]

  @@map("users")
}

model Incident {
  id          String         @id @default(cuid())
  title       String
  type        IncidentType
  severity    Severity
  status      IncidentStatus @default(NEW)
  description String
  source      String?

  creatorId   String
  creator     User           @relation("CreatedBy", fields: [creatorId], references: [id])
  assigneeId  String?
  assignee    User?          @relation("AssignedTo", fields: [assigneeId], references: [id])

  comments    Comment[]
  files       File[]
  auditLogs   AuditLog[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("incidents")
}

model Comment {
  id         String   @id @default(cuid())
  content    String
  type       String   @default("comment") // comment, status_change, assignment, escalation

  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])

  createdAt  DateTime @default(now())

  @@map("comments")
}

model File {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  size         Int
  mimeType     String?

  incidentId   String
  incident     Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])

  createdAt    DateTime @default(now())

  @@map("files")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  details   Json?

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  incidentId String?
  incident   Incident? @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@map("audit_logs")
}
